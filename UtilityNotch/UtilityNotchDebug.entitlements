<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox OFF for Debug builds so MRMediaRemote has the best chance to work.
	     Apple Events still need the Automation entitlement and TCC approval
	     when querying Music.app/Spotify via AppleScript. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.automation.apple-events</key>
	<true/>
	<!-- Microphone input for the Music module's live audio spectrum visualizer.
	     Required even with the sandbox off because Hardened Runtime is enabled:
	     without it macOS denies mic access and the app never appears in
	     System Settings → Privacy & Security → Microphone.
	     Dev reset: tccutil reset Microphone <bundle-id> -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
