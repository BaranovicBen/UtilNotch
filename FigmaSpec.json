  "stateSystem": {
    "name": "DismissalLock",
    "type": "OptionSet (Swift)",
    "description": "Composable lock set — modules insert/remove specific locks. Panel resists auto-close when non-empty.",
    "locks": [
      { "name": "dragDrop",      "rawValue": 1,  "blocksAutoClose": true,  "blocksClickOutside": true,  "triggers": "Any module during file drag-over" },
      { "name": "pickerOpen",    "rawValue": 2,  "blocksAutoClose": true,  "blocksClickOutside": true,  "triggers": "System picker (color, file, date) open" },
      { "name": "activeConvert", "rawValue": 4,  "blocksAutoClose": true,  "blocksClickOutside": true,  "triggers": "FileConverter conversion in progress" },
      { "name": "activeEditing", "rawValue": 8,  "blocksAutoClose": true,  "blocksClickOutside": false, "note": "Does NOT block click-outside — clicking outside unfocuses text field naturally", "triggers": "Any text field focused in any module" },
      { "name": "moduleGesture", "rawValue": 16, "blocksAutoClose": true,  "blocksClickOutside": true,  "triggers": "Drag reorder, scroll momentum" }
    ],
    "computed": {
      "shouldSuppressClose":        "isPointerInsidePanel || !dismissalLocks.isEmpty",
      "shouldSuppressClickOutside": "!dismissalLocks.subtracting(.activeEditing).isEmpty"
    }
  },

  "moduleRegistry": {
    "description": "All modules registered in ModuleRegistry.swift. The ordered array is persisted as enabledModuleIDs in AppState.",
    "defaultOrder": ["todoList", "quickNotes", "clipboardHistory", "musicControl", "fileConverter", "liveActivities", "calendar", "filesTray", "activeApps"],
    "modules": [
      { "id": "todoList",        "label": "Todo List",         "icon": "checklist",                "file": "Modules/TodoList" },
      { "id": "quickNotes",      "label": "Quick Notes",       "icon": "note.text",                "file": "Modules/QuickNotes" },
      { "id": "clipboardHistory","label": "Clipboard History", "icon": "doc.on.clipboard",         "file": "Modules/ClipboardHistory" },
      { "id": "musicControl",    "label": "Music Control",     "icon": "music.note",               "file": "Modules/MusicControl" },
      { "id": "fileConverter",   "label": "File Converter",    "icon": "arrow.2.squarepath",       "file": "Modules/FileConverter" },
      { "id": "liveActivities",  "label": "Live Activities",   "icon": "clock.badge.checkmark",    "file": "Modules/LiveActivities" },
      { "id": "calendar",        "label": "Calendar",          "icon": "calendar",                 "file": "Modules/Calendar" },
      { "id": "filesTray",       "label": "Files Tray",        "icon": "tray",                     "file": "Modules/FilesTray" },
