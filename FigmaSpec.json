  "namingConventions": {
    "figmaPages":       "N · Name (number-prefixed for sort order)",
    "components":       "Shell / ComponentName  or  Module / ComponentName",
    "variants":         "State=default/hover/active/editing/expanded — match Swift @State names",
    "tokens":           "category/subcategory (e.g. overlay/card/hover)",
    "colorStyles":      "UN/{category}/{name}  (e.g. UN/surface/panel, UN/semantic/destructive)",
    "textStyles":       "UN/type/{name}  (e.g. UN/type/headline, UN/type/system/13/semibold)",
    "effectStyles":     "UN/shadow/{name}  (e.g. UN/shadow/panel/expanded)",
    "layerNaming":      "Use Swift view/subview names as Figma layer names for 1-to-1 traceability"
  },

  "figmaPageGuide": {
    "0_Cover": "App name, version, branch, export date, short description",
    "1_Tokens": "Color swatches grid / typography ramp / spacing scale / radii showcase / shadow showcase / motion reference (static annotation)",
    "2_Shell": "NotchPanelView frame (620×380) + DynamicIslandView collapsed (180×36) + DI expanded (620×380) + UtilityRailView isolated + RailButton variants",
    "3_9_Modules": "For each module: empty/demo state frame + populated state frame + all interactive sub-component variants (cards, rows, buttons)",
    "12_StatesInteractions": "DismissalLock state diagram (reference FigJam), panel show/hide flow, module switching, demo→real data transition"
  }
